# Base URL of the Strapi API (include /api suffix)
STRAPI_BASE_URL=http://localhost:1337/api

# Read-only API token used for fetching published content
STRAPI_READ_TOKEN=your-frontend-read-token

# Token with permission to create research submissions
STRAPI_SUBMIT_TOKEN=your-research-submit-token

# Set to "true" to allow search engine indexing (enable at launch)
ALLOW_INDEXING=false

# Production site URL (used for sitemap and OG URLs)
SITE_URL=https://grgurevic.hr
